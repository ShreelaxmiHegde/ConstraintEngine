generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid()) @db.Uuid

  username     String
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())

  guestsession GuestSession[]
  projects     Project[]
  refreshtoken RefreshSession[]
}

model GuestSession {
  id     String  @id @default(uuid()) @db.Uuid
  userId String? @db.Uuid

  createdAt DateTime @default(now())
  expiresAt DateTime

  user User? @relation(fields: [userId], references: [id])

  projects Project[]
}

model RefreshSession {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @db.Uuid
  jwtId     String @unique
  tokenHash String

  createdAt DateTime  @default(now())
  revokedAt DateTime?
  expiresAt DateTime

  replacedBy String?
  ip         String?
  userAgent  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String? @db.Uuid
  guestSessionId String? @db.Uuid

  title                String?
  rawDescription       String
  extractedConstraints Json?

  currentArchitectureVersion Int @default(1)

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  user         User?         @relation(fields: [userId], references: [id])
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id])

  conversations        Conversation[]
  architectureVersions ArchitectureVersion[]
}

model Conversation {
  id        String @id @default(uuid()) @db.Uuid
  projectId String @db.Uuid

  title           String?
  contextSnapshot Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  project Project? @relation(fields: [projectId], references: [id])

  exchanges Exchange[]
}

model Exchange {
  id                    String  @id @default(uuid()) @db.Uuid
  conversationId        String  @db.Uuid
  architectureVersionId String? @db.Uuid

  queryText    String
  responseText String?

  sequenceNumber Int

  exchangeIntent String?
  stateChanged   Boolean @default(false)

  createdAt DateTime @default(now())

  conversation        Conversation         @relation(fields: [conversationId], references: [id])
  architectureVersion ArchitectureVersion? @relation(fields: [architectureVersionId], references: [id])

  @@unique([conversationId, sequenceNumber])
}

model ArchitectureVersion {
  id              String  @id @default(uuid()) @db.Uuid
  projectId       String  @db.Uuid
  parentVersionId String? @db.Uuid

  version Int

  title             String?
  summary           String?
  architectureState Json

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  changes   ArchitectureChange[]
  exchanges Exchange[]
}

model ArchitectureChange {
  id                    String @id @default(uuid()) @db.Uuid
  architectureVersionId String @db.Uuid

  changeType String
  target     String

  oldValue Json?
  newValue Json?

  reasoning String?

  architectureVersion ArchitectureVersion @relation(fields: [architectureVersionId], references: [id])
}
