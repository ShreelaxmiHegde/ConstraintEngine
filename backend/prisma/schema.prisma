generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid()) @db.Uuid

  username     String
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())

  guestsession GuestSession[]
  projects     Project[]
  refreshtoken RefreshSession[]
}

model GuestSession {
  id     String  @id @default(uuid()) @db.Uuid
  userId String? @db.Uuid

  createdAt DateTime @default(now())
  expiresAt DateTime

  user User? @relation(fields: [userId], references: [id])

  projects Project[]
}

model Project {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String? @db.Uuid
  guestSessionId String? @db.Uuid

  title                String?
  rawDescription       String
  extractedConstraints Json?
  architectureState    Json?
  decisions            Json?
  unreslolvedQuestions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id])

  conversations Conversation[]
}

model Conversation {
  id        String  @id @default(uuid()) @db.Uuid
  projectId String? @db.Uuid

  title           String?
  contextSnapshot Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id])

  exchanges Exchange[]
}

model Exchange {
  id             String @id @default(uuid()) @db.Uuid
  conversationId String @db.Uuid

  queryText      String
  responseText   String
  sequenceNumber Int    @default(1)

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, sequenceNumber])
}

model RefreshSession {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @db.Uuid
  jwtId     String @unique
  tokenHash String

  createdAt DateTime  @default(now())
  revokedAt DateTime?
  expiresAt DateTime

  replacedBy String?
  ip         String?
  userAgent  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
